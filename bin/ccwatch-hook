#!/usr/bin/env bash
# ccwatch-hook — Claude Code state-tracking hook.
#
# Reads the hook JSON on stdin, derives a state, and writes it to a per-session
# file in the shared registry. Wired to several hook events in settings.json by
# the installer; the event name and (for Notification) the notification_type
# drive the state.
#
# Subagents (Agent/Task tool) share the parent's session_id in current Claude
# Code, so their events would clobber the parent's row. We ignore them (see
# below) and track only the top-level session, whose own events drive its state.
#
# Registry layout: $CCWATCH_DIR/<session_id>.json
set -euo pipefail

STATE_DIR="${CCWATCH_DIR:-${CLAUDE_INSTANCES_DIR:-${XDG_RUNTIME_DIR:-/tmp}/claude-instances}}"
mkdir -p "$STATE_DIR"

# Project label = name of the enclosing git repo root, so every subdirectory of
# the same project shows the same name. Falls back to the cwd basename when not
# in a repo. Pure Bash (no `git` subprocess) since this runs on every tool call.
project_label() {
  local dir="$1" d name
  [[ -z "$dir" ]] && { echo "unknown"; return; }
  d="$dir"
  while [[ -n "$d" ]]; do
    if [[ -e "$d/.git" ]]; then name="${d##*/}"; echo "${name:-/}"; return; fi
    [[ "$d" == "/" ]] && break
    d="${d%/*}"; [[ -z "$d" ]] && d="/"
  done
  name="${dir##*/}"; echo "${name:-/}"
}

# PID of the owning Claude Code process, recorded so ccwatch can keep an
# open-but-idle session visible and only drop it once that process is gone.
# This hook runs as a (grand)child of `claude`, so walk up the ancestry until we
# find it; fall back to the immediate parent if not. Pure /proc on Linux (cheap,
# since this runs on every tool call); `ps` fallback elsewhere.
_ppid_of() { # $1=pid -> parent pid
  local p="$1" line
  if [[ -r "/proc/$p/stat" ]]; then
    line="$(< "/proc/$p/stat")"; line="${line#*") "}"  # drop "PID (comm) "
    set -- $line; echo "$2"                            # state ppid pgrp ...
  else
    ps -o ppid= -p "$p" 2>/dev/null | tr -d ' '
  fi
}
_comm_of() { # $1=pid -> process name
  local p="$1"
  if [[ -r "/proc/$p/comm" ]]; then
    printf '%s' "$(< "/proc/$p/comm")"
  else
    ps -o comm= -p "$p" 2>/dev/null | sed 's:.*/::'
  fi
}
session_pid() {
  local p="${PPID:-0}" hops=0 c
  while [[ "$p" =~ ^[0-9]+$ ]] && ((p>1 && hops<12)); do
    c="$(_comm_of "$p")"
    [[ "$c" == claude ]] && { echo "$p"; return; }
    p="$(_ppid_of "$p")"; hops=$((hops+1))
  done
  echo "${PPID:-0}"
}

payload="$(cat)"

session_id="$(jq -r '.session_id // "unknown"' <<<"$payload")"
cwd="$(jq -r '.cwd // ""' <<<"$payload")"
event="$(jq -r '.hook_event_name // ""' <<<"$payload")"
notif_type="$(jq -r '.notification_type // ""' <<<"$payload")"
tool_name="$(jq -r '.tool_name // ""' <<<"$payload")"
agent_id="$(jq -r '.agent_id // ""' <<<"$payload")"
agent_type="$(jq -r '.agent_type // ""' <<<"$payload")"
transcript="$(jq -r '.transcript_path // ""' <<<"$payload")"

file="$STATE_DIR/$session_id.json"

# In current Claude Code a subagent (Agent/Task tool) shares the parent's
# session_id, so its hook events — the Subagent* events, plus the tool calls it
# makes, which carry agent_id/agent_type — would clobber the parent's row.
# Worst case they leave the parent stuck "working" after it has gone idle: a
# background agent finishing fires SubagentStop with no following parent event
# to correct it. These events don't describe the top-level session's state, so
# ignore them and let the parent's own events drive it. (Tagging is likewise
# disabled — `agent` stays empty — so the dashboard keeps PID-liveness and a
# subagent's Stop can't delete the live parent's file.)
agent=""
if [[ -n "$agent_id" || -n "$agent_type" || "$event" == Subagent* ]]; then
  exit 0
fi

if [[ "$event" == "SessionEnd" ]]; then
  rm -f "$file"
  exit 0
fi

# Three states: idle (not doing anything), working (processing), waiting_input
# (blocked on the user: a tool-permission approval, or an answer to a question
# / elicitation form).
case "$event" in
  SessionStart)      state="idle" ;;
  Stop)              state="idle" ;;     # end of a top-level turn
  UserPromptSubmit)  state="working" ;;
  PostToolUse)       state="working" ;;  # heartbeat: fires on every tool call
  PreToolUse)
    # AskUserQuestion blocks for the user's answer (no Notification fires for it);
    # every other tool means Claude is actively working.
    if [[ "$tool_name" == "AskUserQuestion" ]]; then state="waiting_input"; else state="working"; fi ;;
  PermissionRequest) state="waiting_input" ;;
  Notification)
    case "$notif_type" in
      permission_prompt|elicitation_dialog) state="waiting_input" ;;
      idle_prompt)                          state="idle" ;;
      *)                                    state="working" ;;
    esac ;;
  *) state="working" ;;
esac

# Human label for the instance: the enclosing git repo name (else cwd basename).
label="$(project_label "$cwd")"

# Focus target — two paths, populated where applicable:
#
#  * `window_match`/`window_title` for plain terminal windows: the tray uses
#    the GNOME `activate-window-by-title` extension to raise the window whose
#    title contains `ccw:<short_id>`. We set that title here via OSC 2.
#
#  * `zellij_session`/`zellij_pane_id` for sessions running inside a zellij
#    pane: the tray uses the zellij CLI to switch focus to that pane. The
#    OSC 2 above still works inside zellij — but zellij consumes it as the
#    *pane title* (visible within zellij's tab bar), not the outer terminal
#    title, which is why title-based focus alone can't raise a zellij-hosted
#    Claude session from a tray click.
short_id="${session_id:0:8}"
window_match="ccw:${short_id}"
window_title="[${window_match}] Claude · ${label} · ${state}"
zellij_session="${ZELLIJ_SESSION_NAME:-}"
zellij_pane_id="${ZELLIJ_PANE_ID:-}"
if [[ -z "$agent" ]]; then
  # Subshell + `exec 2>/dev/null` swallows bash's own redirection error when
  # /dev/tty doesn't exist (hook has no controlling tty); printf would already
  # be silent. `|| true` keeps `set -e` happy on failure.
  ( exec 2>/dev/null; printf '\033]2;%s\007' "$window_title" >/dev/tty ) || true
fi

now="$(date +%s)"
pid="$(session_pid)"; [[ "$pid" =~ ^[0-9]+$ ]] || pid=0

# `updated` = this hook (drives staleness). `since` = when the state last
# CHANGED (drives the AGE display), so heartbeats and other same-state updates
# don't reset AGE. Carry `since` forward when the state is unchanged.
since="$now"
if [[ -f "$file" ]]; then
  prev_state="$(jq -r '.state // ""' "$file" 2>/dev/null || echo "")"
  if [[ "$prev_state" == "$state" ]]; then
    since="$(jq -r '.since // .updated // empty' "$file" 2>/dev/null || echo "$now")"
    [[ -z "$since" ]] && since="$now"
  fi
  # Carry forward the transcript path if this event didn't include one.
  if [[ -z "$transcript" ]]; then
    transcript="$(jq -r '.transcript // empty' "$file" 2>/dev/null || echo "")"
  fi
fi

# Write atomically (temp file + rename) so a concurrent reader (ccwatch) never
# sees a half-written file.
tmp="$file.tmp.$$"
jq -n \
  --arg id "$session_id" \
  --arg cwd "$cwd" \
  --arg label "$label" \
  --arg state "$state" \
  --arg event "$event" \
  --arg agent "$agent" \
  --arg transcript "$transcript" \
  --arg window_match "$window_match" \
  --arg window_title "$window_title" \
  --arg zellij_session "$zellij_session" \
  --arg zellij_pane_id "$zellij_pane_id" \
  --argjson ts "$now" \
  --argjson since "$since" \
  --argjson pid "$pid" \
  '{session_id:$id, label:$label, cwd:$cwd, state:$state, event:$event, agent:$agent, transcript:$transcript, pid:$pid, window_match:$window_match, window_title:$window_title, zellij_session:$zellij_session, zellij_pane_id:$zellij_pane_id, updated:$ts, since:$since}' \
  >"$tmp" && mv -f "$tmp" "$file"

exit 0
