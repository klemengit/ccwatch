#!/usr/bin/env python3
# ccwatch-tray — one GNOME top-bar indicator per Claude Code session.
#
# Watches the same per-session JSON files written by `ccwatch-hook` and renders
# each one as an AyatanaAppIndicator: a coloured dot (green=idle, blue=working,
# amber=waiting input, grey=stale) with the project name as the label, and a
# menu that focuses the host terminal via the `activate-window-by-title` GNOME
# Shell extension (Wayland-safe — the call runs inside the compositor).
#
# Usage: ccwatch-tray            (long-running; Ctrl-C to quit)
#        ccwatch-tray --version
#
# Runtime deps (Ubuntu/Omakub):
#   sudo apt install python3-gi gir1.2-gtk-3.0 gir1.2-ayatanaappindicator3-0.1
# GNOME extension for click-to-focus on Wayland:
#   https://github.com/lucaswerkmeister/activate-window-by-title

from __future__ import annotations

import json
import os
import sys
import time
import subprocess
from pathlib import Path

import gi

gi.require_version("Gtk", "3.0")
gi.require_version("AyatanaAppIndicator3", "0.1")
from gi.repository import Gtk, Gdk, GLib, Gio  # noqa: E402
from gi.repository import AyatanaAppIndicator3 as AppIndicator  # noqa: E402

try:
    import cairo  # type: ignore
except ImportError:
    sys.stderr.write("ccwatch-tray: requires python3-cairo (apt: python3-gi-cairo).\n")
    sys.exit(1)


VERSION = "0.4.0"

STATE_DIR = Path(
    os.environ.get("CCWATCH_DIR")
    or os.environ.get("CLAUDE_INSTANCES_DIR")
    or os.path.join(os.environ.get("XDG_RUNTIME_DIR", "/tmp"), "claude-instances")
)
ICON_DIR = Path(os.environ.get("XDG_RUNTIME_DIR", "/tmp")) / "ccwatch-icons"
STALE_SECS = int(os.environ.get("STALE_SECS", "60"))
GC_SECS = int(os.environ.get("GC_SECS", "1800"))
LABEL_LEN = int(os.environ.get("CCWATCH_LABEL_LEN", "8"))
TICK_SECS = 5  # for staleness re-evaluation; file events drive everything else

# Disc colours (RGB 0..1). Chosen to read on both light and dark GNOME bars.
COLOURS = {
    "idle":          (0.30, 0.69, 0.31),   # green
    "working":       (0.13, 0.59, 0.95),   # blue
    "waiting_input": (1.00, 0.76, 0.03),   # amber
    "stale":         (0.55, 0.55, 0.55),   # grey
}


# ---------------------------------------------------------------------------
# Icon rendering — solid coloured disc, written once per state to ICON_DIR.
# ---------------------------------------------------------------------------

def icon_name(state: str) -> str:
    """Themed icon name (no extension, no path) for `state`."""
    if state not in COLOURS:
        state = "idle"
    return f"cc-{state}"


def ensure_icon(state: str) -> None:
    """Render the PNG for `state` to ICON_DIR/<icon_name>.png if missing.

    AyatanaAppIndicator + the GNOME 'AppIndicator support' extension wants
    themed icon NAMES (looked up in the indicator's theme path), not absolute
    paths — passing a path silently produces an invisible indicator under
    some shell extensions. We give it a name plus a theme-path directory.
    """
    if state not in COLOURS:
        state = "idle"
    path = ICON_DIR / f"{icon_name(state)}.png"
    if path.exists():
        return
    ICON_DIR.mkdir(parents=True, exist_ok=True)
    size = 22
    surface = cairo.ImageSurface(cairo.FORMAT_ARGB32, size, size)
    ctx = cairo.Context(surface)
    ctx.set_operator(cairo.OPERATOR_CLEAR)
    ctx.paint()
    ctx.set_operator(cairo.OPERATOR_OVER)
    r, g, b = COLOURS[state]
    ctx.set_source_rgba(r, g, b, 1.0)
    ctx.arc(size / 2, size / 2, size / 2 - 2, 0, 2 * 3.14159265)
    ctx.fill()
    surface.write_to_png(str(path))


# ---------------------------------------------------------------------------
# Focus via the GNOME Shell extension `activate-window-by-title`. The call
# runs inside the compositor, so it is not blocked by Wayland's focus-stealing
# prevention. If the extension is missing we surface a one-time notification.
# ---------------------------------------------------------------------------

_focus_warned = False


def focus_window(match: str) -> None:
    global _focus_warned
    if not match:
        notify("ccwatch", "No window tag stored for this session yet.")
        return
    try:
        proxy = Gio.DBusProxy.new_for_bus_sync(
            Gio.BusType.SESSION,
            Gio.DBusProxyFlags.NONE,
            None,
            "org.gnome.Shell",
            "/de/lucaswerkmeister/ActivateWindowByTitle",
            "de.lucaswerkmeister.ActivateWindowByTitle",
            None,
        )
        proxy.call_sync(
            "activateBySubstring",
            GLib.Variant("(s)", (match,)),
            Gio.DBusCallFlags.NONE,
            -1,
            None,
        )
    except GLib.Error as exc:
        if not _focus_warned:
            _focus_warned = True
            notify(
                "ccwatch — focus unavailable",
                "Install the 'Activate Window by Title' GNOME extension "
                "(github.com/lucaswerkmeister/activate-window-by-title) "
                "and reload the shell.\n\n" + exc.message,
            )


def notify(title: str, body: str) -> None:
    try:
        subprocess.Popen(
            ["notify-send", "--app-name=ccwatch", title, body],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except FileNotFoundError:
        sys.stderr.write(f"{title}: {body}\n")


# ---------------------------------------------------------------------------
# One AppIndicator per session.
# ---------------------------------------------------------------------------

class SessionIndicator:
    def __init__(self, session_id: str, data: dict) -> None:
        self.session_id = session_id
        self.data: dict = {}
        self._label_text = ""
        self._nudges_left = 3
        # new_with_path tells AppIndicator where to look up icon NAMES — that
        # is the path the GNOME 'AppIndicator support' extension actually uses
        # to resolve `cc-idle`/`cc-working`/etc. into PNGs.
        self.indicator = AppIndicator.Indicator.new_with_path(
            f"ccwatch-{session_id}",
            icon_name("idle"),
            AppIndicator.IndicatorCategory.APPLICATION_STATUS,
            str(ICON_DIR),
        )
        self.indicator.set_status(AppIndicator.IndicatorStatus.ACTIVE)

        self.menu = Gtk.Menu()
        self.header = Gtk.MenuItem(label="(loading)")
        self.header.set_sensitive(False)
        self.menu.append(self.header)
        self.menu.append(Gtk.SeparatorMenuItem())

        self.focus_item = Gtk.MenuItem(label="Focus terminal")
        self.focus_item.connect("activate", self._on_focus)
        self.menu.append(self.focus_item)

        self.copy_item = Gtk.MenuItem(label="Copy cwd")
        self.copy_item.connect("activate", self._on_copy_cwd)
        self.menu.append(self.copy_item)

        self.menu.show_all()
        self.indicator.set_menu(self.menu)
        # Middle-click on indicators that support it = direct focus.
        self.indicator.set_secondary_activate_target(self.focus_item)

        self.update(data, stale=False)
        # The ubuntu-appindicators panel extension learns the label ONLY from
        # the XAyatanaNewLabel DBus signal. If its proxy isn't connected when we
        # first set the label at creation it misses that signal and never
        # re-reads — so the name that's sitting on the bus is never painted
        # (this is the "name shows only sometimes" symptom). Once the proxy is
        # up, re-emit a genuine label change a few times to be caught.
        GLib.timeout_add(1500, self._renudge_label)

    def _set_label(self, text: str) -> None:
        # `guide` reserves layout width so the bar doesn't jiggle on rename.
        self.indicator.set_label(text, "M" * LABEL_LEN)
        self._label_text = text

    def _renudge_label(self) -> bool:
        # libayatana coalesces label changes within one main-loop iteration, so
        # a clear-then-restore in the same tick emits nothing. Instead set a
        # visually identical variant (trailing space) now and restore the clean
        # text on the next tick — two distinct XAyatanaNewLabel emissions the
        # extension can't miss. Repeat a few times in case the proxy is slow.
        guide = "M" * LABEL_LEN
        self.indicator.set_label(self._label_text + " ", guide)
        GLib.timeout_add(200, self._restore_label)
        self._nudges_left -= 1
        return self._nudges_left > 0  # re-fire every 1500ms until exhausted

    def _restore_label(self) -> bool:
        self.indicator.set_label(self._label_text, "M" * LABEL_LEN)
        return False  # one-shot

    def update(self, data: dict, stale: bool) -> None:
        self.data = data
        state = "stale" if stale else (data.get("state") or "idle")
        project = (data.get("label") or "?")
        label_text = project[:LABEL_LEN]
        self.indicator.set_icon_full(icon_name(state), f"{project} ({state})")
        self._set_label(label_text)
        self.indicator.set_title(f"Claude — {project} — {state}")

        pretty_state = state.replace("_", " ")
        cwd = data.get("cwd") or ""
        self.header.set_label(f"{project} · {pretty_state}\n{cwd}")
        self.focus_item.set_label(f"Focus {project}")

    def _on_focus(self, _item) -> None:
        # If the session lives in a zellij pane we can't reliably raise/focus
        # it from outside: zellij swallows the inner OSC 2 title (so GNOME's
        # `activate-window-by-title` has nothing to match on the outer window),
        # and zellij's action CLI exposes no "focus pane by id" verb as of
        # 0.43.x. Surface a notification with the info needed to switch by
        # hand, and still try title-based focus as a best-effort for setups
        # where the user has retitled their terminal externally.
        zellij_session = self.data.get("zellij_session") or ""
        zellij_pane_id = self.data.get("zellij_pane_id") or ""
        project = self.data.get("label") or "?"
        cwd = self.data.get("cwd") or ""
        if zellij_session:
            notify(
                f"ccwatch — {project} is in zellij",
                f"Session: {zellij_session}\n"
                f"Pane id: {zellij_pane_id or '?'}\n"
                f"cwd: {cwd}\n\n"
                "Switch to the pane with zellij's own keybindings — "
                "tray click-to-focus can't target zellij panes "
                "(no focus-pane-by-id CLI in zellij ≤0.43).",
            )
        focus_window(self.data.get("window_match", ""))

    def _on_copy_cwd(self, _item) -> None:
        cwd = self.data.get("cwd") or ""
        if not cwd:
            return
        clipboard = Gtk.Clipboard.get(Gdk.SELECTION_CLIPBOARD)
        clipboard.set_text(cwd, -1)
        clipboard.store()

    def destroy(self) -> None:
        self.indicator.set_status(AppIndicator.IndicatorStatus.PASSIVE)


# ---------------------------------------------------------------------------
# Top-level app: maintains session_id → SessionIndicator from the state files.
# ---------------------------------------------------------------------------

class TrayApp:
    def __init__(self) -> None:
        self.sessions: dict[str, SessionIndicator] = {}
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        gfile = Gio.File.new_for_path(str(STATE_DIR))
        self.monitor = gfile.monitor_directory(Gio.FileMonitorFlags.NONE, None)
        self.monitor.connect("changed", self._on_dir_changed)
        self.refresh()
        GLib.timeout_add_seconds(TICK_SECS, self._tick)

    def _on_dir_changed(self, _mon, _file, _other, _event) -> None:
        # Any change in the directory → rescan. Cheap (a handful of small JSON).
        self.refresh()

    def _tick(self) -> bool:
        # Periodic resweep so stale/GC transitions surface even when no file
        # events arrive (e.g. a hard-killed session leaving a stale file).
        self.refresh()
        return True

    def refresh(self) -> None:
        now = int(time.time())
        seen: set[str] = set()
        for path in STATE_DIR.glob("*.json"):
            # Skip the hook's atomic-write staging files (`<id>.json.tmp.<pid>`)
            # which can briefly appear as siblings during a rename.
            if ".tmp." in path.name:
                continue
            session_id = path.stem
            try:
                data = json.loads(path.read_text())
            except (OSError, json.JSONDecodeError):
                # Mid-write race or stat-after-unlink. If we already track this
                # session, keep its indicator alive so we don't churn dbus and
                # cause "already exported" collisions on the next valid read.
                if session_id in self.sessions:
                    seen.add(session_id)
                continue
            updated = int(data.get("updated") or 0)
            idle = now - updated
            if idle > GC_SECS:
                try:
                    path.unlink()
                except OSError:
                    pass
                continue
            seen.add(session_id)
            stale = idle > STALE_SECS
            if session_id in self.sessions:
                self.sessions[session_id].update(data, stale=stale)
            else:
                self.sessions[session_id] = SessionIndicator(session_id, data)
                self.sessions[session_id].update(data, stale=stale)
        for sid in list(self.sessions):
            if sid not in seen:
                self.sessions[sid].destroy()
                del self.sessions[sid]


def main() -> int:
    args = sys.argv[1:]
    if any(a in ("-v", "--version") for a in args):
        print(f"ccwatch-tray {VERSION}")
        return 0
    if any(a in ("-h", "--help") for a in args):
        print(__doc__ or "ccwatch-tray")
        return 0

    # Pre-render the four icon variants up front so first state changes are
    # snappy and disk I/O happens off the GTK main loop.
    for s in COLOURS:
        ensure_icon(s)

    _check_appindicator_support()

    print(f"ccwatch-tray {VERSION} — watching {STATE_DIR}", file=sys.stderr)
    TrayApp()
    try:
        Gtk.main()
    except KeyboardInterrupt:
        pass
    return 0


def _check_appindicator_support() -> None:
    """Warn once if no GNOME extension is exposing AppIndicators.

    GNOME Shell itself does not render StatusNotifierItem icons. Ubuntu/Omakub
    usually ship `ubuntu-appindicators@ubuntu.com` enabled, but some setups
    require installing `appindicatorsupport@rgcjonas.gmail.com` manually. If
    neither is present, the indicators we register are simply invisible —
    which looks like ccwatch-tray is broken.
    """
    try:
        out = subprocess.run(
            ["gnome-extensions", "list", "--enabled"],
            check=False, capture_output=True, text=True, timeout=2,
        ).stdout
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return
    enabled = out.splitlines()
    wanted = ("ubuntu-appindicators@ubuntu.com",
              "appindicatorsupport@rgcjonas.gmail.com")
    if not any(w in enabled for w in wanted):
        notify(
            "ccwatch — tray icons may be hidden",
            "No GNOME AppIndicator extension is enabled. Install\n"
            "`gnome-shell-extension-appindicator` (or the\n"
            "`AppIndicator and KStatusNotifierItem Support` extension\n"
            "from extensions.gnome.org) and enable it.",
        )
        print(
            "ccwatch-tray: warning — no AppIndicator support extension enabled; "
            "icons will not be visible until you enable one.",
            file=sys.stderr,
        )


if __name__ == "__main__":
    sys.exit(main())
